---
import Base from '../layouts/Base.astro';
import head from '../snippets/qui-suis-je.head.html?raw';
import body from '../snippets/qui-suis-je.body.html?raw';
const title = "Qui est Eva Naudet, coach holistique | Mon parcours";
const description = "De l'effondrement à la renaissance : l'histoire d'Eva Naudet, coach holistique qui accompagne les femmes à se reconnecter à leur puissance intérieure.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
