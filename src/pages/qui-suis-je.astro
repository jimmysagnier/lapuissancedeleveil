---
import Base from '../layouts/Base.astro';
import head from '../snippets/qui-suis-je.head.html?raw';
import body from '../snippets/qui-suis-je.body.html?raw';
const title = "Qui suis-je — La Puissance de l'Éveil / Eva Naudet";
const description = "Eva Naudet, coach holistique. L'histoire d'une femme qui a porté, encaissé, tenu — jusqu'à ce que son corps dise stop. Et ce qu'elle accompagne aujourd'hui.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
