---
import Base from '../layouts/Base.astro';
import head from '../snippets/les-cles.head.html?raw';
import body from '../snippets/les-cles.body.html?raw';
const title = "Les Clés — La Puissance de l'Éveil / Eva Naudet";
const description = "Les outils d'Eva Naudet — trois ebooks et la lecture Human Design. Des clés à toi, à ouvrir à ton rythme.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
