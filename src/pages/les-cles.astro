---
import Base from '../layouts/Base.astro';
import head from '../snippets/les-cles.head.html?raw';
import body from '../snippets/les-cles.body.html?raw';
const title = "Ebooks & lecture Human Design à ton rythme | Eva Naudet";
const description = "Trois ebooks et une lecture Human Design pour avancer à ton rythme : déconstruire tes pensées, lâcher prise, te révéler. À ouvrir quand c'est l'heure.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
