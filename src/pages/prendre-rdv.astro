---
import Base from '../layouts/Base.astro';
import head from '../snippets/prendre-rdv.head.html?raw';
import body from '../snippets/prendre-rdv.body.html?raw';
const title = "Prendre rendez-vous | Eva Naudet, coach holistique";
const description = "Choisis ton créneau pour ton appel découverte gratuit de 30 minutes en visio avec Eva Naudet. Le premier pas vers toi, sans engagement.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
