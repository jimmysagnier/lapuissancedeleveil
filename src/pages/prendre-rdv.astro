---
import Base from '../layouts/Base.astro';
import head from '../snippets/prendre-rdv.head.html?raw';
import body from '../snippets/prendre-rdv.body.html?raw';
const title = "Prendre rendez-vous — La Puissance de l'Éveil / Eva Naudet";
const description = "Choisis ton créneau pour l'appel découverte gratuit de 30 minutes avec Eva Naudet, coach holistique.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
