---
import Base from '../layouts/Base.astro';
import head from '../snippets/mentions-legales.head.html?raw';
import body from '../snippets/mentions-legales.body.html?raw';
const title = "Mentions légales | La Puissance de l'Éveil";
const description = "Mentions légales du site La Puissance de l'Éveil, édité par Eva Naudet, coach holistique. Éditeur, hébergeur et informations légales.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
