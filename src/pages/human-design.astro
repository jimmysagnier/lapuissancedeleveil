---
import Base from '../layouts/Base.astro';
import head from '../snippets/human-design.head.html?raw';
import body from '../snippets/human-design.body.html?raw';
const title = "Le Human Design · La Puissance de l'Éveil / Eva Naudet";
const description = "Le Human Design, expliqué sans jargon. Type, autorité intérieure, bodygraph, prise de décision. Une page guide par Eva Naudet, La Puissance de l'Éveil.";
