---
import Base from '../layouts/Base.astro';
import head from '../snippets/human-design.head.html?raw';
import body from '../snippets/human-design.body.html?raw';
const title = "Le Human Design, c'est quoi ? Guide complet | Eva Naudet";
const description = "Comprendre le Human Design : ton type, ton autorité, ton design unique. Un guide clair pour décoder qui tu es et t'aligner enfin avec ta vraie nature.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
