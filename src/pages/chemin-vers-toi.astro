---
import Base from '../layouts/Base.astro';
import head from '../snippets/chemin-vers-toi.head.html?raw';
import body from '../snippets/chemin-vers-toi.body.html?raw';
const title = "Le chemin vers toi — La Puissance de l'Éveil / Eva Naudet";
const description = "Un accompagnement holistique pour arrêter de subir et commencer à vivre une vie qui te ressemble. Eva Naudet, coach holistique.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
