---
import Base from '../layouts/Base.astro';
import head from '../snippets/chemin-vers-toi.head.html?raw';
import body from '../snippets/chemin-vers-toi.body.html?raw';
const title = "Accompagnement holistique : se reconstruire | Eva Naudet";
const description = "Un accompagnement holistique de 6 mois pour les femmes en renaissance : sortir du mode survie, te retrouver, te révéler. Découvre le parcours RE'NAI'SENS.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
