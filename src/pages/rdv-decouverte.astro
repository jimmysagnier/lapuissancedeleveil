---
import Base from '../layouts/Base.astro';
import head from '../snippets/rdv-decouverte.head.html?raw';
import body from '../snippets/rdv-decouverte.body.html?raw';
const title = "Appel découverte gratuit (30 min) | Eva Naudet, coach";
const description = "30 minutes, sans pression, pour voir si on est faites pour avancer ensemble. Réserve ton appel découverte gratuit avec Eva Naudet, coach holistique.";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
