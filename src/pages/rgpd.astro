---
import Base from '../layouts/Base.astro';
import head from '../snippets/rgpd.head.html?raw';
import body from '../snippets/rgpd.body.html?raw';
const title = "Politique de confidentialité (RGPD) | Eva Naudet";
const description = "Comment vos données personnelles sont collectées, utilisées et protégées sur le site La Puissance de l'Éveil, en conformité avec le RGPD (Eva Naudet).";
---
<Base title={title} description={description}>
<Fragment slot="head" set:html={head} />
<Fragment set:html={body} />
</Base>
